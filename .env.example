# ─── Database ─────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string
# Format: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ─── Authentication ───────────────────────────────────────────────────
# Secret key for signing JWT session tokens (generate a strong random string)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ─── OpenAI ───────────────────────────────────────────────────────────
# API key for OpenAI (used for AI chat responses and lead scoring)
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Facebook / Meta ─────────────────────────────────────────────────
# Facebook App credentials for Messenger integration
FACEBOOK_APP_ID=1971848976777445
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Webhook verification token (must match what you set in Meta Developer Console)
FACEBOOK_VERIFY_TOKEN=rocketeer_verify_token_2024

# Your app's public URL (used for OAuth redirect and webhook URLs)
APP_URL=https://rocketeerio.vercel.app

# ─── PayMongo ────────────────────────────────────────────────────────
# PayMongo API keys for subscription billing
PAYMONGO_SECRET_KEY=sk_test_placeholder
PAYMONGO_PUBLIC_KEY=pk_test_placeholder

# ─── Hot Lead Alert Channels (Optional) ──────────────────────────────
# SMTP credentials for email alerts (defaults to Gmail SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# Telegram Bot token for Telegram alerts
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# WhatsApp Business API (placeholder — wire to your provider)
# WHATSAPP_API_URL=https://graph.facebook.com/v19.0/YOUR_PHONE_ID/messages
# WHATSAPP_API_TOKEN=your-whatsapp-api-token

# SMS provider (placeholder — wire to Twilio or similar)
# SMS_API_URL=https://api.twilio.com/2010-04-01/Accounts/YOUR_SID/Messages.json
# SMS_API_TOKEN=YOUR_SID:YOUR_AUTH_TOKEN
# SMS_FROM_NUMBER=+1234567890

# ─── Optional ─────────────────────────────────────────────────────────
# Override the OpenAI base URL (for proxies or compatible APIs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Override the LLM model (defaults to gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini

# Override the owner email for automatic admin role assignment
# OWNER_EMAIL=jandrickclimaco@gmail.com

# Node environment (production/development)
NODE_ENV=production

# Server port (for standalone Express mode, not needed on Vercel)
# PORT=3000

# Google Maps API key (optional, only needed for the Map component)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
